        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9.39.4",
        "eslint-config-next": "16.2.2",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
